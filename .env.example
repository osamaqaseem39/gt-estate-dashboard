# API server origin (no /api suffix). Dashboard requests use /api/* on this host.
NEXT_PUBLIC_API_URL=https://gt-estate-server-zhly.vercel.app

# File upload API (gallery + property images): POST multipart; response JSON uses data.url (see upload.php).
# Prefer this name; NEXT_PUBLIC_GALLERY_UPLOAD_URL is an alias if unset.
NEXT_PUBLIC_UPLOAD_API_URL=https://gt.osamaqaseem.online/upload.php
# NEXT_PUBLIC_GALLERY_UPLOAD_URL=https://gt.osamaqaseem.online/upload.php
# Add your dashboard origin to upload.php $allowed_origins (e.g. https://your-app.vercel.app).
# Optional: multipart field name for the file (default "file").
# NEXT_PUBLIC_UPLOAD_API_FIELD=file
# NEXT_PUBLIC_GALLERY_UPLOAD_FIELD=file

# Max image size in bytes before calling the upload API (default 5242880 = 5 MiB). Match server MAX_IMAGE_UPLOAD_BYTES.
# NEXT_PUBLIC_MAX_IMAGE_UPLOAD_BYTES=5242880
