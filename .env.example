# API server origin (no /api suffix). Dashboard requests use /api/* on this host.
NEXT_PUBLIC_API_URL=https://gt-estate-server-zhly.vercel.app

# Gallery file uploads: POST multipart to this script; response JSON uses data.url (see upload.php).
NEXT_PUBLIC_GALLERY_UPLOAD_URL=https://gt.osamaqaseem.online/upload.php
# Add your dashboard origin to upload.php $allowed_origins (e.g. https://your-app.vercel.app).
# Optional: form field name for the file (PHP often uses "file").
# NEXT_PUBLIC_GALLERY_UPLOAD_FIELD=file
